# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy from Project Settings → API

# Server-side (API routes, server components) — never exposed to the browser
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Client-side (browser + SSR helpers) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# "anon / public" key from Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model for main chat responses and draft generation
# anthropic/claude-sonnet-4 (quality) or anthropic/claude-haiku-4 (speed/cost)
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for auth callback URLs and OpenRouter's HTTP-Referer header.
# Local development: http://localhost:3000
# Production on Vercel: https://your-app.vercel.app or your custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — from `stripe listen` locally or Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...