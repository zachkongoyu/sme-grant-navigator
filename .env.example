# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy from Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model for main chat responses and draft generation
# anthropic/claude-sonnet-4 (quality) or anthropic/claude-haiku-4 (speed/cost)
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── App URL ───────────────────────────────────────────────────────────────────
# Used in OpenRouter's HTTP-Referer header (required). Set to your production URL before deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (Week 3 — payment gate) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Auth (Week 3) ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000